public static int querySegmentTree(int start,int end,int i,int l,int r){
        if(l>end || r<start){
            return 0;
        }
        if(l>=start && r<=end){
            return segTree[i];
        }

        // overlapping case.....
        int mid=l+(r-1)/2;
        return querySegmentTree(start,end,2*i+1,0,mid)+querySegment(start,end,2*i+2,mid+1,r);
    }
