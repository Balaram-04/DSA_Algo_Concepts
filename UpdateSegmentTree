public static void updateSegmentTree(int index,int val,int i,int l,int r){
        if(l==r){
            segTree[i]=val;
            return;
        }
        int mid=l+(r-l)/2;
        if(index<=mid){
            updateSegmentTree(index,val,2*i+1,l,mid);
        }
        else{
            updateSegmentTree(index,val,2*i+2,mid+1,r);
        }
        segTree[i]=segTree[2*i+1]+segTree[2*i+2];
    }
