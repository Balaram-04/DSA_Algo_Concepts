public static void buildTree(int i,int l,int r,int[] arr,int[] segTree){
        
        //base Case:
        if(l==r){
            segTree[i]=arr[l];
        }
        int mid=l+(r-l)/2;
        buildTree(2*i+1,l,mid,arr,segTree);
        buildTree(2*i+2,mid+1,r,arr,segTree);
        segTree[i]=SegTree[2*i+1]+segTree[2*i+2];
    }
